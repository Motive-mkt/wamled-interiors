{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "worker"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Potential client inquiry",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "projectType": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "In Progress", "Closed"] },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Service": {
      "title": "Service",
      "description": "Offered service description",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Studio product for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" }
      }
    },
    "Invite": {
      "title": "Invite",
      "description": "Registration invite code",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "used": { "type": "boolean" },
        "usedBy": { "type": "string" }
      }
    },
    "SiteContent": {
      "title": "Site Content",
      "description": "CMS content for the website",
      "type": "object",
      "properties": {
        "heroHeadline": { "type": "string" },
        "heroImage": { "type": "string" },
        "location": { "type": "string" },
        "hours": { "type": "string" },
        "phone": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "Dynamic Portfolio Project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "scopeOfWork": { "type": "string" },
        "gallery": { "type": "array" },
        "createdAt": { "type": "string" }
      }
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Client review or testimonial item",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "author": { "type": "string" },
        "title": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "leads/{leadId}": {
      "schema": "Lead",
      "description": "Inquiries from the website"
    },
    "services/{serviceId}": {
      "schema": "Service",
      "description": "List of services"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "List of products"
    },
    "invites/{code}": {
      "schema": "Invite",
      "description": "Invite codes for registration"
    },
    "site_content/{page}": {
      "schema": "SiteContent",
      "description": "Dynamic page content"
    },
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Dynamic portfolio projects list"
    },
    "testimonials/{testimonialId}": {
      "schema": "Testimonial",
      "description": "Client reviews & testimonials"
    }
  }
}
