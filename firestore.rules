rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner() {
      return isSignedIn() && getUserData().role == 'owner';
    }

    function isWorker() {
      return isSignedIn() && getUserData().role == 'worker';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isOwner());
      allow create: if isSignedIn() && request.auth.uid == userId && (
        (request.auth.token.email == "jessescaledyou@gmail.com" && request.resource.data.role == "owner") ||
        (request.resource.data.role == "worker")
      );
      allow update: if isOwner();
    }

    // Invites
    match /invites/{code} {
      allow get: if true; // Anyone can check a code validity
      allow list, write: if isOwner();
    }

    // Site Content
    match /site_content/{contentId} {
      allow read: if true;
      allow write: if isOwner();
    }

    // Services
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isOwner();
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isOwner();
    }

    // Leads
    match /leads/{leadId} {
      allow create: if true;
      allow read, update: if isOwner() || isWorker();
      allow delete: if isOwner();
    }
  }
}
