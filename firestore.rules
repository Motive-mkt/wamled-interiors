rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role == 'owner';
    }

    function isWorker() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role == 'worker';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isOwner());
      allow create: if isSignedIn() && request.auth.uid == userId && (
        (request.auth.token.email == "jessescaledyou@gmail.com" && request.resource.data.role == "owner") ||
        (request.resource.data.role == "worker")
      );
      allow update: if isOwner() || (isSignedIn() && request.auth.uid == userId && request.auth.token.email == "jessescaledyou@gmail.com");
    }

    // Leads
    match /leads/{leadId} {
      allow read: if isOwner() || isWorker();
      allow create: if true; // Public can submit leads
      allow update, delete: if isOwner();
    }

    // Services & Products
    match /services/{id} {
      allow read: if true;
      allow write: if isOwner();
    }
    match /products/{id} {
      allow read: if true;
      allow write: if isOwner();
    }

    // Invites
    match /invites/{code} {
      allow get: if true;
      allow list, write: if isOwner();
    }

    // Site Content
    match /site_content/{page} {
      allow read: if true;
      allow write: if isOwner();
    }
  }
}
