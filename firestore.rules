rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role == 'owner';
    }

    function isWorker() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role == 'worker';
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isOwner());
      allow create: if isSignedIn() && request.auth.uid == userId && (
        (request.auth.token.email == "jessescaledyou@gmail.com" && request.resource.data.role == "owner") ||
        (request.resource.data.role == "worker")
      );
      allow update: if isOwner() || (isSignedIn() && request.auth.uid == userId && request.auth.token.email == "jessescaledyou@gmail.com");
    }

    // Invites
    match /invites/{code} {
      allow get: if true;
      allow list, write: if isOwner();
    }

    // Site Content
    match /site_content/{contentId} {
      allow read: if true;
      allow write: if isOwner();
    }

    // Services
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isOwner();
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isOwner();
    }

    // Leads
    match /leads/{leadId} {
      allow create: if true;
      allow read, update: if isOwner() || isWorker();
      allow delete: if isOwner();
    }
  }
}
