rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isOwner() {
      return isSignedIn() && hasUserDoc() && getUserData().role == 'owner';
    }

    function isWorker() {
      return isSignedIn() && hasUserDoc() && (getUserData().role == 'worker' || getUserData().role == 'owner');
    }

    // Rules for the Users Collection
    match /users/{userId} {
      // Users can read their own profile; only owners can manage profiles or see others
      allow read: if isSignedIn() && (request.auth.uid == userId || isOwner());
      // Let any signed-in user write their initial doc (required for self-initialization code)
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update, delete: if isOwner();
    }

    // Rules for Protected Business Assets
    match /leads/{leadId} {
      allow read, write: if isWorker(); // Both workers and owners can access leads
    }

    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isOwner(); // Only owners can update pricing/services
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }
  }
}
